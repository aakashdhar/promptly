{
  "name": "promptly",
  "version": "1.0.0",
  "description": "macOS floating bar that turns speech into structured Claude prompts",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "vite",
    "build:renderer": "vite build",
    "start:react": "npm run build:renderer && electron .",
    "dist": "electron-builder --universal",
    "lint": "eslint main.js preload.js"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.1",
    "electron": "41.2.1",
    "electron-builder": "26.8.1",
    "eslint": "9.24.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "vite": "^8.0.8"
  },
  "build": {
    "appId": "io.betacraft.promptly",
    "productName": "Promptly",
    "mac": {
      "category": "public.app-category.productivity",
      "hardenedRuntime": true,
      "entitlements": "entitlements.plist",
      "entitlementsInherit": "entitlements.plist",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "universal"
          ]
        }
      ]
    },
    "dmg": {
      "title": "Promptly"
    },
    "files": [
      "main.js",
      "preload.js",
      "splash.html",
      "dist-renderer/**",
      "package.json"
    ]
  }
}
