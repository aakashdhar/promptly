{
  "name": "promptly",
  "version": "1.0.0",
  "description": "macOS floating bar that turns speech into structured Claude prompts",
  "author": {
    "name": "Aakash Dhar",
    "email": "aakash.dhar@sorigin.com"
  },
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "vite",
    "build:renderer": "vite build",
    "start:react": "npm run build:renderer && electron .",
    "dist": "electron-builder --universal",
    "lint": "eslint main.js preload.js",
    "dist:unsigned": "npm run build:renderer && electron-builder --mac --universal --config.mac.identity=null",
    "create-cert": "bash scripts/create-cert.sh",
    "sign-app": "bash scripts/sign-app.sh",
    "dist:signed": "bash scripts/build-signed.sh"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@vitejs/plugin-react": "^6.0.1",
    "canvas": "^3.2.3",
    "electron": "41.2.1",
    "electron-builder": "26.8.1",
    "eslint": "9.24.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tailwindcss": "^4.2.2",
    "vite": "^8.0.8"
  },
  "build": {
    "appId": "io.betacraft.promptly",
    "productName": "Promptly",
    "icon": "build/icon",
    "mac": {
      "category": "public.app-category.productivity",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "entitlements.plist",
      "entitlementsInherit": "entitlements.plist",
      "minimumSystemVersion": "12.0",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "universal"
          ]
        }
      ],
      "extendInfo": {
        "NSMicrophoneUsageDescription": "Promptly needs microphone access to record your voice for prompt generation."
      }
    },
    "dmg": {
      "title": "Promptly"
    },
    "files": [
      "main.js",
      "preload.js",
      "splash.html",
      "dist-renderer/**",
      "package.json"
    ]
  }
}
